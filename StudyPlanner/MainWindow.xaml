<Window x:Class="StudyPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudyPlanner"
        mc:Ignorable="d"
        Title="망각곡선 학습 플래너" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        FontFamily="맑은 고딕" FontSize="14">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 왼쪽: 학습 주제 입력 폼 ===== -->
        <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="학습 주제 등록" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <TextBlock Text="과목" Margin="0,0,0,3"/>
                <TextBox x:Name="txtSubject" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="단원 / 주제" Margin="0,0,0,3"/>
                <TextBox x:Name="txtUnit" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="학습일" Margin="0,0,0,3"/>
                <DatePicker x:Name="dpStudyDate" Margin="0,0,0,10"/>

                <TextBlock Text="메모" Margin="0,0,0,3"/>
                <TextBox x:Name="txtMemo" Margin="0,0,0,15" Padding="5" Height="80"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <Button x:Name="btnAdd" Content="등록" Height="38" Click="btnAdd_Click"
                        Background="#3F51B5" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ===== 오른쪽: 등록된 학습 주제 목록 ===== -->
        <DockPanel Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" Text="등록된 학습 주제"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <DataGrid x:Name="dgTopics" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="32">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="과목" Binding="{Binding Subject}" Width="100"/>
                    <DataGridTextColumn Header="단원/주제" Binding="{Binding Unit}" Width="*"/>
                    <DataGridTextColumn Header="학습일"
                                        Binding="{Binding StudyDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                    <DataGridTextColumn Header="다음 복습일"
                                        Binding="{Binding NextReviewDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
