<Window x:Class="StudyPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudyPlanner"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="망각곡선 학습 플래너" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        FontFamily="맑은 고딕" FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">

    <TabControl Margin="10">

        <!-- ============ 탭 0: 대시보드 ============ -->
        <TabItem Header="대시보드">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 요약 카드 3개 -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Background="#3F51B5" UniformCornerRadius="8"
                                         Padding="20" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="학습 주제" Foreground="White" FontSize="14" Opacity="0.85"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="txtTotalTopics" Text="0" Foreground="White"
                                           FontSize="38" FontWeight="Bold"/>
                                <TextBlock Text="개 등록됨" Foreground="White" FontSize="12" Opacity="0.85"
                                           VerticalAlignment="Bottom" Margin="6,0,0,9"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Background="#E91E63" UniformCornerRadius="8"
                                         Padding="20" Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="오늘 복습" Foreground="White" FontSize="14" Opacity="0.85"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="txtTodayReview" Text="0" Foreground="White"
                                           FontSize="38" FontWeight="Bold"/>
                                <TextBlock Text="건 예정" Foreground="White" FontSize="12" Opacity="0.85"
                                           VerticalAlignment="Bottom" Margin="6,0,0,9"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="2" Background="#009688" UniformCornerRadius="8"
                                         Padding="20" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="다가오는 시험" Foreground="White" FontSize="14" Opacity="0.85"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="txtNextExamDay" Text="—" Foreground="White"
                                           FontSize="38" FontWeight="Bold"/>
                                <TextBlock x:Name="txtNextExamLabel" Text="등록된 시험 없음"
                                           Foreground="White" FontSize="12" Opacity="0.85"
                                           VerticalAlignment="Bottom" Margin="6,0,0,9"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- 우하단 구석: 시연용 알림 트리거 (작은 종 아이콘 버튼) -->
                <Button Grid.Row="2" x:Name="btnNotify"
                        Click="btnNotify_Click"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="지금 알림 받기 (시연용)"
                        HorizontalAlignment="Right" Margin="0,8,0,0"
                        Foreground="#999">
                    <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20"/>
                </Button>

                <!-- 차트 2개 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" UniformCornerRadius="8" Padding="14" Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="과목별 학습 주제 분포"
                                       FontSize="15" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="등록한 학습 주제를 과목별로 묶어서 보여줍니다."
                                       FontSize="11" Foreground="#666" Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            <lvc:CartesianChart x:Name="chartSubject"/>
                        </DockPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" UniformCornerRadius="8" Padding="14" Margin="8,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="향후 14일 복습 일정"
                                       FontSize="15" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="다음 2주간 매일 몇 개의 주제를 복습해야 하는지 보여줍니다. SM-2 알고리즘이 자동으로 분산해 배치합니다."
                                       FontSize="11" Foreground="#666" Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            <lvc:CartesianChart x:Name="chartSchedule"/>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ============ 탭 1: 학습 주제 ============ -->
        <TabItem Header="학습 주제">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 학습 주제 입력 폼 -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="학습 주제 등록" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>

                        <TextBox x:Name="txtSubject"
                                 Style="{StaticResource MaterialDesignFilledTextBox}"
                                 materialDesign:HintAssist.Hint="과목"
                                 Margin="0,0,0,14"/>

                        <TextBox x:Name="txtUnit"
                                 Style="{StaticResource MaterialDesignFilledTextBox}"
                                 materialDesign:HintAssist.Hint="단원 / 주제"
                                 Margin="0,0,0,14"/>

                        <DatePicker x:Name="dpStudyDate"
                                    Style="{StaticResource MaterialDesignFilledDatePicker}"
                                    materialDesign:HintAssist.Hint="학습일"
                                    Margin="0,0,0,14"/>

                        <TextBox x:Name="txtMemo"
                                 Style="{StaticResource MaterialDesignFilledTextBox}"
                                 materialDesign:HintAssist.Hint="메모"
                                 Margin="0,0,0,20" Height="92"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Button x:Name="btnAdd" Click="btnAdd_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Height="42">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="등록"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>

                <!-- 오른쪽: 등록된 학습 주제 목록 -->
                <DockPanel Grid.Column="1">
                    <TextBlock DockPanel.Dock="Top" Text="등록된 학습 주제"
                               FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="dgTopics"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" RowHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="과목" Binding="{Binding Subject}" Width="100"/>
                            <DataGridTextColumn Header="단원/주제" Binding="{Binding Unit}" Width="*"/>
                            <DataGridTextColumn Header="학습일"
                                                Binding="{Binding StudyDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTextColumn Header="다음 복습일"
                                                Binding="{Binding NextReviewDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTextColumn Header="반복"
                                                Binding="{Binding RepetitionCount}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </TabItem>

        <!-- ============ 탭 2: 오늘의 복습 ============ -->
        <TabItem Header="오늘의 복습">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="310"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 오늘 복습할 항목 목록 -->
                <DockPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock DockPanel.Dock="Top" x:Name="txtReviewCount"
                               Text="오늘 복습할 항목" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="dgReview"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="36"
                              SelectionChanged="dgReview_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="과목" Binding="{Binding Subject}" Width="100"/>
                            <DataGridTextColumn Header="단원/주제" Binding="{Binding Unit}" Width="*"/>
                            <DataGridTextColumn Header="복습 예정일"
                                                Binding="{Binding NextReviewDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                            <DataGridTextColumn Header="반복" Binding="{Binding RepetitionCount}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- 오른쪽: 자가 평가 패널 -->
                <materialDesign:Card Grid.Column="1" UniformCornerRadius="8" Padding="18">
                    <StackPanel>
                        <TextBlock Text="자가 평가" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtSelected" Text="복습할 항목을 선택하세요."
                                   TextWrapping="Wrap" Margin="0,0,0,16" Foreground="#666"/>
                        <TextBlock Text="이번 복습, 얼마나 기억났나요?"
                                   Margin="0,0,0,10" FontWeight="Bold"/>

                        <Button Content="5 — 완벽하게 기억남" Tag="5" Click="btnRate_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,0,6" Height="36"
                                HorizontalContentAlignment="Left" Padding="14,0"/>
                        <Button Content="4 — 약간 머뭇거림" Tag="4" Click="btnRate_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,0,6" Height="36"
                                HorizontalContentAlignment="Left" Padding="14,0"/>
                        <Button Content="3 — 어렵게 기억함" Tag="3" Click="btnRate_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,0,6" Height="36"
                                HorizontalContentAlignment="Left" Padding="14,0"/>
                        <Button Content="2 — 가물가물 (실패)" Tag="2" Click="btnRate_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,0,6" Height="36"
                                HorizontalContentAlignment="Left" Padding="14,0"/>
                        <Button Content="1 — 거의 못함 (실패)" Tag="1" Click="btnRate_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,0,6" Height="36"
                                HorizontalContentAlignment="Left" Padding="14,0"/>
                        <Button Content="0 — 전혀 모름 (실패)" Tag="0" Click="btnRate_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,0,6" Height="36"
                                HorizontalContentAlignment="Left" Padding="14,0"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </TabItem>

        <!-- ============ 탭 3: 시험 D-Day ============ -->
        <TabItem Header="시험 D-Day">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 시험 등록 + 일정 생성 -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="시험 등록" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>

                        <TextBox x:Name="txtExamSubject"
                                 Style="{StaticResource MaterialDesignFilledTextBox}"
                                 materialDesign:HintAssist.Hint="과목"
                                 Margin="0,0,0,14"/>

                        <TextBox x:Name="txtExamName"
                                 Style="{StaticResource MaterialDesignFilledTextBox}"
                                 materialDesign:HintAssist.Hint="시험명 (예: 중간고사)"
                                 Margin="0,0,0,14"/>

                        <DatePicker x:Name="dpExamDate"
                                    Style="{StaticResource MaterialDesignFilledDatePicker}"
                                    materialDesign:HintAssist.Hint="시험일"
                                    Margin="0,0,0,18"/>

                        <Button x:Name="btnAddExam" Click="btnAddExam_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Height="42" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarPlus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="시험 등록"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="0,0,0,12"/>
                        <TextBlock Text="목록에서 시험을 선택한 뒤 누르면, 해당 과목 학습 주제들의 복습 일정을 시험일 기준으로 재배치합니다."
                                   TextWrapping="Wrap" Foreground="#666" FontSize="12" Margin="0,0,0,10"/>

                        <Button x:Name="btnGenPlan" Click="btnGenPlan_Click"
                                Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                Height="42">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="시험 대비 복습 일정 생성"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>

                <!-- 오른쪽: 시험 목록 (D-Day) -->
                <DockPanel Grid.Column="1">
                    <TextBlock DockPanel.Dock="Top" Text="등록된 시험"
                               FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="dgExams"
                              Style="{StaticResource MaterialDesignDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="D-Day" Binding="{Binding DDayText}" Width="80"/>
                            <DataGridTextColumn Header="과목" Binding="{Binding Subject}" Width="120"/>
                            <DataGridTextColumn Header="시험명" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="시험일"
                                                Binding="{Binding ExamDate, StringFormat=yyyy-MM-dd}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
