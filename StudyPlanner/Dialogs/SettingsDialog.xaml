<Window x:Class="StudyPlanner.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="설정"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="440"
        FontFamily="맑은 고딕" FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="설정" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>

            <!-- 자동 알림 섹션 -->
            <TextBlock Text="매일 자동 알림" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="정해진 시간에 '오늘 복습할 항목 N건' 트레이 알림을 받습니다."
                       FontSize="12" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,12"/>

            <CheckBox x:Name="chkNotifyEnabled"
                      Style="{StaticResource MaterialDesignCheckBox}"
                      Content="매일 자동 알림 활성화"
                      Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="알림 시각:"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbHour" Grid.Column="1"
                          Style="{StaticResource MaterialDesignFilledComboBox}"
                          materialDesign:HintAssist.Hint="시"/>
                <TextBlock Grid.Column="2" Text=" : "
                           VerticalAlignment="Center" FontWeight="Bold" FontSize="16"
                           Margin="6,0,6,0"/>
                <ComboBox x:Name="cmbMinute" Grid.Column="3"
                          Style="{StaticResource MaterialDesignFilledComboBox}"
                          materialDesign:HintAssist.Hint="분"/>
            </Grid>

            <Separator Margin="0,0,0,14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소" Click="btnCancel_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,8,0" MinWidth="80"/>
                <Button Content="저장 (Enter)" Click="btnSave_Click" IsDefault="True"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        MinWidth="100"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
