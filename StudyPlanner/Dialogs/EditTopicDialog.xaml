<Window x:Class="StudyPlanner.Dialogs.EditTopicDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="학습 주제 편집"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="420"
        FontFamily="맑은 고딕" FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="학습 주제 편집" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>

            <TextBox x:Name="txtSubject"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="과목"
                     Margin="0,0,0,14"/>

            <TextBox x:Name="txtUnit"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="단원 / 주제"
                     Margin="0,0,0,14"/>

            <DatePicker x:Name="dpStudyDate"
                        Style="{StaticResource MaterialDesignFilledDatePicker}"
                        materialDesign:HintAssist.Hint="학습일"
                        Margin="0,0,0,14"/>

            <TextBox x:Name="txtMemo"
                     Style="{StaticResource MaterialDesignFilledTextBox}"
                     materialDesign:HintAssist.Hint="메모"
                     Margin="0,0,0,20" Height="88"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소" Click="btnCancel_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,8,0" MinWidth="80"/>
                <Button Content="저장" Click="btnSave_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        MinWidth="80"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
